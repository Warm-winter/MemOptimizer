<Window x:Class="MemOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MemOptimizer" Height="500" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        FontFamily="{StaticResource MainFont}"
        Loaded="Window_Loaded">

    <Border x:Name="MainBorder"
            CornerRadius="16"
            BorderThickness="1"
            BorderBrush="#20FFFFFF"
            Margin="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#0F0F1E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <!-- 项目 Logo -->
                        <Image Source="Assets/logo.png" Width="22" Height="22" Margin="0,0,10,0" Stretch="UniformToFill"/>
                        <TextBlock Text="MemOptimizer" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                        <!-- 齿轮按钮 -->
                        <Button x:Name="BtnSettings" Style="{StaticResource TitleBarBtn}" Click="BtnSettings_Click" ToolTip="关于">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="{StaticResource TextSecondaryBrush}"
                                  Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                        </Button>
                        <Button Style="{StaticResource TitleBarBtn}" Click="BtnMinimize_Click" ToolTip="最小化">
                            <TextBlock Text="—" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                        </Button>
                        <Button Style="{StaticResource TitleBarBtn}" Click="BtnClose_Click" ToolTip="关闭">
                            <TextBlock Text="✕" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <Grid Grid.Row="1" Margin="24,8,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 环形进度条 -->
                <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,15">
                    <Viewbox Width="200" Height="200">
                        <Grid>
                            <!-- 背景圆环 -->
                            <Ellipse Width="160" Height="160" Stroke="#20FFFFFF" StrokeThickness="10"/>
                            <!-- 进度圆弧 -->
                            <Canvas Width="160" Height="160">
                                <Path x:Name="ProgressArc" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#4A9EFF" Offset="0"/>
                                            <GradientStop Color="#00D4FF" Offset="0.5"/>
                                            <GradientStop Color="#00E676" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Path.Stroke>
                                </Path>
                            </Canvas>
                            <!-- 中心文字 -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="PercentText" Text="0%" FontSize="36" FontWeight="Bold"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOptimizing}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="内存使用率" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Viewbox>
                </Grid>

                <!-- 内存信息卡片 -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 可用内存 -->
                    <Border Grid.Column="0" Background="#15FFFFFF" CornerRadius="10" Padding="12,10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="可用" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AvailableMemoryText}" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 已用内存 -->
                    <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="10" Padding="12,10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="已用" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding UsedMemoryText}" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 总内存 -->
                    <Border Grid.Column="4" Background="#15FFFFFF" CornerRadius="10" Padding="12,10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="总计" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalMemoryText}" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 优化按钮 -->
                <Button Grid.Row="2" x:Name="BtnOptimize"
                        Style="{StaticResource OptimizeButton}"
                        Height="48"
                        Command="{Binding OptimizeCommand}"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- 优化中旋转图标 -->
                        <Ellipse x:Name="LoadingDot" Width="14" Height="14" Margin="0,0,10,0"
                                 Fill="{StaticResource TextPrimaryBrush}" Visibility="Collapsed"/>
                        <TextBlock x:Name="BtnText" Text="一键优化" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 状态文本 -->
                <TextBlock Grid.Row="3" x:Name="StatusBlock"
                           Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0"
                           MaxWidth="340"/>
            </Grid>

            <!-- 关于弹窗 -->
            <Popup x:Name="AboutPopup"
                   PlacementTarget="{Binding ElementName=BtnSettings}"
                   Placement="Bottom"
                   HorizontalOffset="-145"
                   VerticalOffset="4"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Width="320" CornerRadius="12" BorderThickness="1" BorderBrush="#30FFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#252542" Offset="0"/>
                            <GradientStop Color="#1A1A2E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel Margin="24,20">
                        <!-- Logo -->
                        <Image Source="Assets/logo.png" Width="56" Height="56" Stretch="UniformToFill"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>

                        <!-- 项目名 -->
                        <TextBlock Text="MemOptimizer" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>

                        <!-- 版本 -->
                        <TextBlock Text="v1.0.0" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

                        <!-- 简介 -->
                        <TextBlock Text="轻量级 Windows 内存优化工具，基于系统级 API 清理文件缓存，一键释放内存。"
                                   FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,16"/>

                        <!-- 分割线 -->
                        <Border Height="1" Background="#20FFFFFF" Margin="0,0,0,16"/>

                        <!-- GitHub 按钮 -->
                        <Button Click="BtnGitHub_Click" Cursor="Hand" Margin="0,0,0,12">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="GhBd" CornerRadius="8" Background="#15FFFFFF" Padding="16,10">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <!-- GitHub Logo (from SVG path) -->
                                            <Path Width="18" Height="18" Stretch="Uniform" Fill="White" Margin="0,0,10,0"
                                                  Data="M41.4395 69.3848C28.8066 67.8535 19.9062 58.7617 19.9062 46.9902C19.9062 42.2051 21.6289 37.0371 24.5 33.5918C23.2559 30.4336 23.4473 23.7344 24.8828 20.959C28.7109 20.4805 33.8789 22.4902 36.9414 25.2656C40.5781 24.1172 44.4062 23.543 49.0957 23.543C53.7852 23.543 57.6133 24.1172 61.0586 25.1699C64.0254 22.4902 69.2891 20.4805 73.1172 20.959C74.457 23.543 74.6484 30.2422 73.4043 33.4961C76.4668 37.1328 78.0937 42.0137 78.0937 46.9902C78.0937 58.7617 69.1934 67.6621 56.3691 69.2891C59.623 71.3945 61.8242 75.9883 61.8242 81.252L61.8242 91.2051C61.8242 94.0762 64.2168 95.7031 67.0879 94.5547C84.4102 87.9512 98 70.6289 98 49.1914C98 22.1074 75.9883 0 48.9043 0C21.8203 0 0 22.1074 0 49.1914C0 70.4375 13.4941 88.0469 31.6777 94.6504C34.2617 95.6074 36.75 93.8848 36.75 91.3008L36.75 83.6445C35.4102 84.2188 33.6875 84.6016 32.1562 84.6016C25.8398 84.6016 22.1074 81.1563 19.4277 74.7441C18.375 72.1602 17.2266 70.6289 15.0254 70.3418C13.877 70.2461 13.4941 69.7676 13.4941 69.1934C13.4941 68.0449 15.4082 67.1836 17.3223 67.1836C20.0977 67.1836 22.4902 68.9063 24.9785 72.4473C26.8926 75.2227 28.9023 76.4668 31.2949 76.4668C33.6875 76.4668 35.2187 75.6055 37.4199 73.4043C39.0469 71.7773 40.291 70.3418 41.4395 69.3848Z"/>
                                            <TextBlock Text="GitHub 仓库" FontSize="13" FontWeight="Medium"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="GhBd" Property="Background" Value="#25FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- License -->
                        <TextBlock Text="MIT License · Copyright © 2026 Warm-winter" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
